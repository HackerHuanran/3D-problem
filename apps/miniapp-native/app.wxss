page {
  background: #f4f8fc;
  color: #132033;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

.page {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.panel,
.hero-card,
.card,
.empty-box {
  background: rgba(250, 252, 255, 0.98);
  border: 1rpx solid rgba(34, 56, 89, 0.08);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(21, 42, 77, 0.06);
}

.hero-card,
.panel,
.empty-box {
  padding: 28rpx;
}

.hero-card {
  background: linear-gradient(145deg, #fdfefe 0%, #edf4fb 100%);
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #132033;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #617791;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.btn-primary,
.btn-ghost,
.btn-danger {
  border-radius: 999rpx;
  font-size: 26rpx;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #2568e8 0%, #18b5d4 100%);
  color: #fff;
}

.btn-ghost {
  background: rgba(37, 104, 232, 0.08);
  color: #2568e8;
}

.btn-danger {
  background: rgba(214, 84, 84, 0.12);
  color: #c94141;
}

.search-input,
.text-input {
  height: 84rpx;
  background: #eef4fb;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #132033;
}

.chip-row {
  white-space: nowrap;
}

.chip {
  display: inline-flex;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #edf2f7;
  color: #5f748e;
  font-size: 24rpx;
  margin-right: 14rpx;
  margin-bottom: 14rpx;
}

.chip.active {
  background: rgba(37, 104, 232, 0.12);
  color: #2568e8;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card {
  padding: 24rpx;
}

.meta {
  font-size: 22rpx;
  color: #7a8fa8;
}

.badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(24, 181, 212, 0.12);
  color: #127b91;
  font-size: 22rpx;
}
