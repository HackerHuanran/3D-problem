<view class="page" wx:if="{{detail}}">
  <view class="hero-card">
    <text class="title">{{detail.title}}</text>
    <text class="subtitle">{{detail.description}}</text>
    <view class="row" style="margin-top: 18rpx;">
      <view>
        <text class="badge">{{detail.category}}</text>
        <text class="badge" style="margin-left: 12rpx;">{{detail.status}}</text>
      </view>
      <text class="meta">{{detail.budget ? ('预算：' + detail.budget) : '预算未填'}}</text>
    </view>
  </view>

  <view class="panel">
    <text class="title" style="font-size: 30rpx;">联系与说明</text>
    <text class="subtitle" style="margin-top: 18rpx;">{{detail.contact ? ('联系方式：' + detail.contact) : '暂未填写联系方式'}}</text>
    <view class="row" style="margin-top: 20rpx;">
      <text class="meta">浏览 {{detail.viewCount || 0}}</text>
      <text class="meta">感兴趣 {{detail.interestCount || 0}}</text>
    </view>
  </view>
</view>

<view wx:if="{{!detail && missingCollection}}" class="page">
  <view class="empty-box">
    <text class="title" style="font-size: 34rpx;">需求功能还没启用</text>
    <text class="subtitle">当前云环境缺少 `{{missingCollection}}` 集合，创建后这里就能显示需求详情。</text>
  </view>
</view>

<view wx:if="{{!detail && !missingCollection && loadError}}" class="page">
  <view class="empty-box">
    <text class="title" style="font-size: 34rpx;">需求详情加载失败</text>
    <text class="subtitle">{{loadError}}</text>
  </view>
</view>

<view wx:if="{{!detail && !missingCollection && !loadError}}" class="page">
  <view class="empty-box">
    <text class="title" style="font-size: 34rpx;">没找到这条需求</text>
    <text class="subtitle">可能已经删除，或者当前环境里还没有同步到这条数据。</text>
  </view>
</view>
