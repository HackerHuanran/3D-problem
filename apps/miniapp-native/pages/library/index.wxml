<view class="page">
  <view class="hero-card">
    <text class="title">问题库</text>
    <text class="subtitle">按现象直接搜索，或者先筛分类，再进入问题详情看原因和解决步骤。</text>
  </view>

  <view class="panel">
    <view class="row" style="margin-bottom: 20rpx;">
      <text class="title" style="font-size: 32rpx;">直接搜索问题</text>
      <text class="meta">共 {{problems.length}} 条</text>
    </view>

    <input class="search-input" placeholder="搜索翘边、拉丝、堵嘴、层移…" value="{{query}}" bindinput="onQueryInput" />

    <scroll-view scroll-x class="chip-row" style="margin-top: 20rpx;">
      <view wx:for="{{categories}}" wx:key="*this" class="chip {{activeCategory === item ? 'active' : ''}}" data-category="{{item}}" bindtap="selectCategory">
        {{item}}
      </view>
    </scroll-view>

    <view wx:if="{{loading}}" class="loading-box">
      <text class="loading-text">正在加载问题库...</text>
    </view>

    <view wx:elif="{{problems.length}}" class="list" style="margin-top: 20rpx;">
      <view wx:for="{{problems}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="openDetail">
        <image class="problem-cover" src="{{item.image_url || '/assets/home-cards/problem-search.svg'}}" mode="aspectFill"></image>
        <view class="row">
          <text class="title" style="font-size: 30rpx; flex:1;">{{item.title}}</text>
          <text class="badge">{{item.category}}</text>
        </view>
        <text class="subtitle">{{item.subtitle}}</text>
        <view class="row" style="margin-top: 16rpx;">
          <view>
            <text wx:if="{{item.stages && item.stages.length}}" class="meta">{{item.stages[0]}}</text>
            <text wx:if="{{item.estimatedTime}}" class="meta" style="margin-left: 16rpx;">{{item.estimatedTime}}</text>
          </view>
          <text wx:if="{{favoriteMap[item.id]}}" class="meta">已收藏</text>
        </view>
      </view>
    </view>

    <view wx:else class="loading-box">
      <text class="loading-text">暂无匹配结果</text>
    </view>

    <view wx:if="{{loadingMore}}" class="meta" style="text-align:center; padding: 18rpx 0;">正在加载更多…</view>
    <view wx:elif="{{!hasMore}}" class="meta" style="text-align:center; padding: 18rpx 0;">没有更多了</view>
  </view>

</view>
