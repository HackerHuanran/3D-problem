<view class="page">
  <view wx:if="{{loading}}" class="empty-box">
    <text class="title" style="font-size: 34rpx;">正在加载问题详情...</text>
    <text class="subtitle">请稍等一下，内容马上出来。</text>
  </view>

  <view wx:elif="{{detail}}">
    <view class="hero-card">
      <text class="title">{{detail.title}}</text>
      <text class="subtitle">{{detail.subtitle}}</text>
      <view class="row" style="margin-top: 18rpx;">
        <view>
          <text class="badge">{{detail.category}}</text>
          <text wx:if="{{detail.estimatedTime}}" class="badge" style="margin-left: 12rpx;">{{detail.estimatedTime}}</text>
        </view>
        <button class="btn-ghost" size="mini" bindtap="toggleFavorite">{{isFav ? '已收藏' : '收藏'}}</button>
      </view>
    </view>

    <view class="panel">
      <text class="title" style="font-size: 30rpx;">常见原因</text>
      <view class="list" style="margin-top: 18rpx;">
        <view wx:for="{{detail.causes}}" wx:key="*this" class="card">
          <text class="subtitle">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="panel">
      <text class="title" style="font-size: 30rpx;">解决步骤</text>
      <view class="list" style="margin-top: 18rpx;">
        <view wx:for="{{detail.solutions}}" wx:key="step" class="card">
          <text class="meta">步骤 {{item.step}}</text>
          <text class="title" style="font-size: 28rpx; margin-top: 10rpx;">{{item.title}}</text>
          <text class="subtitle">{{item.detail}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{detail.tips}}" class="panel">
      <text class="title" style="font-size: 30rpx;">补充提醒</text>
      <text class="subtitle" style="margin-top: 18rpx;">{{detail.tips}}</text>
    </view>

    <view wx:if="{{related.length}}" class="panel">
      <text class="title" style="font-size: 30rpx;">相关问题</text>
      <view class="list" style="margin-top: 18rpx;">
        <view wx:for="{{related}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="openRelated">
          <text class="title" style="font-size: 28rpx;">{{item.title}}</text>
          <text class="subtitle">{{item.subtitle}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty-box">
    <text class="title" style="font-size: 34rpx;">没找到这个问题</text>
    <text class="subtitle">可能是这个问题还没有同步到小程序端。</text>
  </view>
</view>
