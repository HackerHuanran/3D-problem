<view class="page">
  <view class="home-search-card">
    <view class="home-search-head">
      <view>
        <text class="title home-title">已收录 {{problemCount}} 个问题</text>
        <text class="subtitle home-subtitle">直接搜问题名，或者点下面入口进入对应模块。</text>
      </view>
    </view>
    <view class="search-bar">
      <input
        class="search-input home-search-input"
        placeholder="搜索翘边、拉丝、堵嘴、层移…"
        value="{{searchValue}}"
        confirm-type="search"
        bindinput="onSearchInput"
        bindconfirm="searchProblems"
      />
      <button class="btn-primary search-btn" bindtap="searchProblems">搜索</button>
    </view>
    <button class="btn-primary share-btn" bindtap="goShareProblem">分享打印问题</button>
  </view>

  <view class="entry-grid">
    <view
      wx:for="{{entryCards}}"
      wx:key="id"
      class="entry-card {{item.layout === 'hero' ? 'entry-card-hero' : 'entry-card-half'}}"
      data-id="{{item.id}}"
      bindtap="openEntry"
    >
      <image class="entry-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="entry-overlay">
        <text class="entry-title">{{item.title}}</text>
        <text class="entry-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="panel diagnosis-panel">
    <view class="row" style="margin-bottom: 16rpx;">
      <text class="title" style="font-size: 32rpx;">不知道问题名？</text>
      <text class="meta">适合新手</text>
    </view>
    <text class="subtitle">如果你还说不清具体故障名，可以先走一次诊断初筛，再决定看哪条问题。</text>
    <button class="btn-primary diagnosis-btn" bindtap="goDiagnosis">去做初筛</button>
  </view>

  <view wx:if="{{historyProblems.length}}" class="panel">
    <view class="row" style="margin-bottom: 20rpx;">
      <text class="title" style="font-size: 32rpx;">最近浏览</text>
      <text class="meta">{{historyProblems.length}} 条</text>
    </view>

    <view class="list">
      <view wx:for="{{historyProblems}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="openDetail">
        <view class="row">
          <text class="title" style="font-size: 30rpx; flex:1;">{{item.title}}</text>
          <text class="badge">最近浏览</text>
        </view>
        <text class="subtitle">{{item.subtitle}}</text>
      </view>
    </view>
  </view>
</view>
