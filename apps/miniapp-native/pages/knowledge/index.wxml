<view class="page">
  <view class="hero-card">
    <text class="title">知识库</text>
    <text class="subtitle">先把常见概念讲明白，再去解决具体问题，会更容易上手。</text>
  </view>

  <view class="panel">
    <text class="title" style="font-size: 32rpx;">搜索知识</text>
    <input class="search-input" placeholder="搜索首层、回抽、热床、风扇…" value="{{query}}" bindinput="onSearchInput" />
  </view>

  <view class="list">
    <view wx:for="{{filteredSections}}" wx:key="id" class="card">
      <text class="title" style="font-size: 30rpx;">{{item.title}}</text>
      <text class="subtitle">{{item.desc}}</text>
      <view class="bullet-list">
        <view wx:for="{{item.items}}" wx:key="*this" class="bullet-item">
          <text class="bullet-dot"></text>
          <text class="meta" style="flex:1; line-height: 1.7;">{{item}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
