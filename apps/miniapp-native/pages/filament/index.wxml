<view class="page">
  <view class="hero-card">
    <text class="title">耗材参数库</text>
    <text class="subtitle">先按材料筛选，再看推荐喷嘴、热床和速度区间，适合小程序里快速查参数。</text>
  </view>

  <view class="panel">
    <input class="search-input" placeholder="搜索品牌、材料、型号…" value="{{query}}" bindinput="onQueryInput" />

    <scroll-view scroll-x class="chip-row" style="margin-top: 20rpx;">
      <view wx:for="{{materials}}" wx:key="*this" class="chip {{activeMaterial === item ? 'active' : ''}}" data-material="{{item}}" bindtap="selectMaterial">
        {{item}}
      </view>
    </scroll-view>
  </view>

  <view class="list">
    <view wx:for="{{items}}" wx:key="id" class="card">
      <view class="row">
        <view style="flex:1;">
          <text class="title" style="font-size: 30rpx;">{{item.brand}} · {{item.variant}}</text>
          <text class="subtitle">{{item.material}} · {{item.difficulty}} · {{item.source}}</text>
        </view>
        <text class="badge">{{item.material}}</text>
      </view>

      <view class="metrics-grid">
        <view class="metric-box">
          <text class="metric-label">喷嘴</text>
          <text class="metric-value">{{item.nozzleRec}}°C</text>
        </view>
        <view class="metric-box">
          <text class="metric-label">热床</text>
          <text class="metric-value">{{item.bedRec}}°C</text>
        </view>
        <view class="metric-box">
          <text class="metric-label">速度</text>
          <text class="metric-value">{{item.speedRec}}mm/s</text>
        </view>
        <view class="metric-box">
          <text class="metric-label">风扇</text>
          <text class="metric-value">{{item.fanSpeed}}%</text>
        </view>
      </view>

      <view class="chip-wrap">
        <text wx:for="{{item.tags}}" wx:key="*this" class="mini-chip">{{item}}</text>
      </view>

      <text class="subtitle" style="margin-top: 18rpx;">{{item.tips}}</text>
    </view>
  </view>
</view>
